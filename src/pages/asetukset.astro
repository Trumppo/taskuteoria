---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Asetukset | TaskuTeoria">
  <section class="card">
    <h1>Asetukset</h1>
    <p>Muokkaa paivatavoitetta, metronomia ja aanenvoimakkuutta. Kaikki tallennetaan laitteellesi.</p>
  </section>

  <section class="card">
    <label for="goal">Paivan tavoite (min)</label>
    <input id="goal" type="range" min="3" max="20" step="1" />
    <p class="small" id="goal-value"></p>

    <label for="bpm">Metronomi BPM</label>
    <input id="bpm" type="range" min="40" max="220" step="1" />
    <p class="small" id="bpm-value"></p>

    <label for="gain">Master gain</label>
    <input id="gain" type="range" min="1" max="80" step="1" />
    <p class="small" id="gain-value"></p>
  </section>

  <section class="card grid">
    <button id="save" class="btn" type="button">Tallenna</button>
    <button id="reset-settings" class="btn ghost" type="button">Palauta oletukset</button>
  </section>

  <script>
    import initAsetukset from "../lib/pages/asetukset";

    initAsetukset();
  </script>
</BaseLayout>
