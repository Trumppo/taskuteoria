---
import BaseLayout from "../layouts/BaseLayout.astro";
import learningPath from "../content/path/14-day.json";
---

<BaseLayout title="Polku | TaskuTeoria" active="polku">
  <section class="card">
    <h1>{learningPath.title}</h1>
    <p>{learningPath.intro}</p>
  </section>
  {learningPath.days.map((item) => (
    <section class="card"><p>{item.range}: {item.focus}</p></section>
  ))}
</BaseLayout>
