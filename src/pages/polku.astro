---
import BaseLayout from "../layouts/BaseLayout.astro";
import learningPath from "../content/path/14-day.json";
import { withBase } from "../lib/base";
---

<BaseLayout title="Polku | TaskuTeoria" active="polku">
  <section class="card">
    <h1>{learningPath.title}</h1>
    <p>{learningPath.intro}</p>
    <p class="small">Klikkaa paivan otsikkoa avataksesi harjoitukset.</p>
  </section>

  {learningPath.days.map((day, idx) => (
    <section class="card day-card">
      <button class="day-toggle" type="button" data-day-toggle={idx} aria-expanded="false">
        <strong>{day.title}</strong>: {day.summary}
      </button>
      <div class="day-panel" data-day-panel={idx} hidden>
        <ul>
          {day.steps.map((step) => (
            <li>{step.label}</li>
          ))}
        </ul>
        <a class="btn" href={withBase(`polku/${day.id}`)}>Aloita paiva</a>
      </div>
    </section>
  ))}

  <script>
    import initPolku from "../lib/pages/polku";

    initPolku();
  </script>
</BaseLayout>
