---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Pikavisa | TaskuTeoria" active="harjoittele">
  <section class="card">
    <h1>Pikavisa</h1>
    <p>Viiden kysymyksen sekoitus nuoteista, rytmista, savellajeista ja kuuntelusta.</p>
    <p class="small" id="quiz-progress">Kysymys 1/5</p>
    <p class="small" id="quiz-score">Pisteet: 0</p>
  </section>

  <section class="card">
    <h2 id="quiz-question">Ladataan...</h2>
    <p class="small" id="quiz-type"></p>
    <div class="grid" id="quiz-options"></div>
    <p class="small" id="quiz-feedback" aria-live="polite">Valitse vastaus.</p>
  </section>

  <section class="card grid">
    <button id="quiz-play" type="button" class="btn ghost">Soita tehtava</button>
    <button id="quiz-next" type="button" class="btn">Seuraava</button>
  </section>

  <script>
    import initPikavisa from "../lib/pages/pikavisa";

    const data = {
      notes: JSON.parse('{JSON.stringify(noteDeck.notes)}'),
      intervals: JSON.parse('{JSON.stringify(listeningDeck.intervals)}'),
      chords: JSON.parse('{JSON.stringify(listeningDeck.chords)}'),
      keyQuestions: JSON.parse('{JSON.stringify(keyDeck.questions)}'),
      timeSignatures: JSON.parse('{JSON.stringify(rhythmDeck.timeSignatures)}'),
    };
    initPikavisa(data);
  </script>
</BaseLayout>
