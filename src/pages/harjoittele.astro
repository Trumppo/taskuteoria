---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/base";
---

<BaseLayout title="Harjoittele | TaskuTeoria" active="harjoittele">
  <section class="card">
    <h1>Harjoittele</h1>
    <p>Valitse yksi osa-alue ja keskity siihen ilman muita osioita samalla sivulla.</p>
  </section>

  <section class="card">
    <div class="landing-grid">
      <a class="card tile" href={withBase("nuotit")}>
        <h3>Nuotit</h3>
        <p class="small">Tunnista savel viivastolta ja harjoittele klaavit.</p>
      </a>
      <a class="card tile" href={withBase("rytmi")}>
        <h3>Rytmi</h3>
        <p class="small">Naputus + drag & drop -tahti.</p>
      </a>
      <a class="card tile" href={withBase("savellajit")}>
        <h3>Savellajit</h3>
        <p class="small">Kysymykset C-duurista ja a-mollista.</p>
      </a>
    </div>
  </section>

  <section class="card">
    <a class="btn ghost" href={withBase("valitsin")}>Siirry harjoitusvalitsimeen</a>
  </section>
</BaseLayout>
