---
import BaseLayout from "../layouts/BaseLayout.astro";
import noteDeck from "../content/decks/note-identification.json";
import rhythmDeck from "../content/decks/rhythm-values.json";
---

<BaseLayout title="Harjoittele | TaskuTeoria" active="harjoittele">
  <section class="card">
    <h1>{noteDeck.title}</h1>
    <p>{noteDeck.description} Saat valittoman palautteen ja pisteet tallentuvat laitteellesi.</p>
    <div class="note" id="target-note">?</div>
    <p class="small" id="feedback">Aloita harjoitus.</p>
  </section>

  <section class="card">
    <div class="grid" id="choices"></div>
  </section>

  <section class="card">
    <button class="btn ghost" id="play-btn" type="button">Soita nuotti</button>
    <p class="small" id="stats"></p>
  </section>

  <section class="card">
    <h2>Rytmiharjoitus</h2>
    <p>Napauta 4 tasaiselle iskulle metronomin mukana. Saat palautteen ajoituksen tarkkuudesta.</p>
    <p class="small" id="rhythm-status">Valmis. Paina Aloita.</p>
    <div class="grid">
      <button class="btn" id="rhythm-start" type="button">Aloita rytmi</button>
      <button class="btn ghost" id="rhythm-tap" type="button" disabled>NAPUTA</button>
      <button class="btn ghost" id="rhythm-stop" type="button" disabled>Lopeta</button>
    </div>
  </section>

  <section class="card">
    <h2>Tahti drag & drop</h2>
    <p>Raahaa nuottiarvoja tahtiin niin, että kokonaiskesto on {rhythmDeck.targetBeats} iskua ({rhythmDeck.timeSignature}).</p>
    <div class="grid" id="rhythm-palette"></div>
    <div id="rhythm-dropzone" class="dropzone" aria-label="Tahtialue"></div>
    <p class="small" id="rhythm-dd-status">Tahti: 0 / {rhythmDeck.targetBeats} iskua</p>
    <div class="grid">
      <button class="btn" id="rhythm-dd-check" type="button">Tarkista tahti</button>
      <button class="btn ghost" id="rhythm-dd-reset" type="button">Tyhjenna</button>
    </div>
  </section>

  <script type="module">
    import { playMetronome, playNote, setMasterGain } from "../lib/audio/synth.ts";
    import { addPracticeMinutes, loadProgress, saveProgress, registerSession } from "../lib/progress.ts";
    import { loadSettings } from "../lib/settings.ts";

    const notes = JSON.parse('{JSON.stringify(noteDeck.notes)}');
    const rhythmDeck = JSON.parse('{JSON.stringify(rhythmDeck)}');
    const settings = loadSettings();
    setMasterGain(settings.masterGain);

    const targetEl = document.getElementById("target-note");
    const feedbackEl = document.getElementById("feedback");
    const choicesEl = document.getElementById("choices");
    const statsEl = document.getElementById("stats");
    const playBtn = document.getElementById("play-btn");
    const rhythmStatusEl = document.getElementById("rhythm-status");
    const rhythmStartBtn = document.getElementById("rhythm-start");
    const rhythmTapBtn = document.getElementById("rhythm-tap");
    const rhythmStopBtn = document.getElementById("rhythm-stop");
    const rhythmPaletteEl = document.getElementById("rhythm-palette");
    const rhythmDropzoneEl = document.getElementById("rhythm-dropzone");
    const rhythmDdStatusEl = document.getElementById("rhythm-dd-status");
    const rhythmDdCheckBtn = document.getElementById("rhythm-dd-check");
    const rhythmDdResetBtn = document.getElementById("rhythm-dd-reset");

    let current = notes[Math.floor(Math.random() * notes.length)];
    let progress = registerSession();
    let stopMetro = null;
    let rhythmRunning = false;
    let startAt = 0;
    let expectedTimes = [];
    let taps = [];
    const beatCount = 4;
    const timingWindowMs = 140;
    let draggedPieceId = null;
    let measure = [];

    function renderStats() {
      const noteRatio = progress.stats.noteTotal
        ? Math.round((progress.stats.noteCorrect / progress.stats.noteTotal) * 100)
        : 0;
      const rhythmRatio = progress.stats.rhythmTotal
        ? Math.round((progress.stats.rhythmCorrect / progress.stats.rhythmTotal) * 100)
        : 0;
      statsEl.textContent = `Nuotit: ${progress.stats.noteCorrect}/${progress.stats.noteTotal} (${noteRatio} %) | Rytmi: ${progress.stats.rhythmCorrect}/${progress.stats.rhythmTotal} (${rhythmRatio} %) | Putki: ${progress.streak}`;
    }

    function nextRound() {
      current = notes[Math.floor(Math.random() * notes.length)];
      targetEl.textContent = current.name;
      feedbackEl.textContent = "Mika vaihtoehto vastaa nuottia?";
    }

    notes.forEach((n) => {
      const b = document.createElement("button");
      b.className = "btn";
      b.type = "button";
      b.textContent = n.name;
      b.addEventListener("click", () => {
        const ok = n.name === current.name;
        progress.stats.noteTotal += 1;
        if (ok) progress.stats.noteCorrect += 1;
        saveProgress(progress);
        progress = addPracticeMinutes(0.35);
        feedbackEl.textContent = ok ? "Oikein!" : `Vaarin. Oikea oli ${current.name}.`;
        renderStats();
        window.setTimeout(nextRound, 700);
      });
      choicesEl.appendChild(b);
    });

    playBtn.addEventListener("click", () => playNote(current.midi));

    function resetRhythmUi() {
      rhythmTapBtn.disabled = true;
      rhythmStopBtn.disabled = true;
      rhythmStartBtn.disabled = false;
      rhythmRunning = false;
      if (stopMetro) stopMetro();
      stopMetro = null;
    }

    function finishRhythm() {
      if (!rhythmRunning) return;
      const count = Math.min(taps.length, expectedTimes.length);
      const offsets = [];
      for (let i = 0; i < count; i += 1) {
        offsets.push(Math.abs(taps[i] - expectedTimes[i]));
      }
      const average = offsets.length
        ? Math.round(offsets.reduce((a, b) => a + b, 0) / offsets.length)
        : 999;

      const isCorrect = count === beatCount && offsets.every((v) => v <= timingWindowMs);
      progress.stats.rhythmTotal += 1;
      if (isCorrect) progress.stats.rhythmCorrect += 1;
      saveProgress(progress);
      progress = addPracticeMinutes(0.75);
      renderStats();

      rhythmStatusEl.textContent = isCorrect
        ? `Hyva! Keskipoikkeama ${average} ms.`
        : `Yrita uudelleen. Keskipoikkeama ${average} ms, tavoite <= ${timingWindowMs} ms.`;
      resetRhythmUi();
    }

    rhythmStartBtn.addEventListener("click", () => {
      const beatMs = 60000 / settings.metronomeBpm;
      startAt = performance.now() + beatMs;
      expectedTimes = Array.from({ length: beatCount }, (_, i) => startAt + i * beatMs);
      taps = [];
      rhythmRunning = true;
      rhythmStatusEl.textContent = `Naputa ${beatCount} iskua (${settings.metronomeBpm} BPM).`;
      rhythmTapBtn.disabled = false;
      rhythmStopBtn.disabled = false;
      rhythmStartBtn.disabled = true;
      if (stopMetro) stopMetro();
      stopMetro = playMetronome(settings.metronomeBpm, settings.defaultTimeSig);
      window.setTimeout(() => {
        if (rhythmRunning) finishRhythm();
      }, beatMs * (beatCount + 1));
    });

    rhythmTapBtn.addEventListener("click", () => {
      if (!rhythmRunning) return;
      taps.push(performance.now());
      if (taps.length >= beatCount) finishRhythm();
    });

    rhythmStopBtn.addEventListener("click", () => {
      rhythmStatusEl.textContent = "Rytmiharjoitus keskeytetty.";
      resetRhythmUi();
    });

    function beatsInMeasure() {
      return measure.reduce((sum, piece) => sum + Number(piece.beats), 0);
    }

    function renderMeasure() {
      rhythmDropzoneEl.innerHTML = "";
      measure.forEach((piece, index) => {
        const chip = document.createElement("div");
        chip.className = "dropchip";
        chip.textContent = `${piece.label} (${piece.beats})`;
        chip.title = "Napauta poistaaksesi";
        chip.addEventListener("click", () => {
          measure.splice(index, 1);
          renderMeasure();
        });
        rhythmDropzoneEl.appendChild(chip);
      });
      rhythmDdStatusEl.textContent = `Tahti: ${beatsInMeasure()} / ${rhythmDeck.targetBeats} iskua`;
    }

    rhythmDeck.pieces.forEach((piece) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "btn ghost";
      btn.textContent = `${piece.label} (${piece.beats})`;
      btn.draggable = true;
      btn.addEventListener("dragstart", () => {
        draggedPieceId = piece.id;
      });
      btn.addEventListener("click", () => {
        measure.push(piece);
        renderMeasure();
      });
      rhythmPaletteEl.appendChild(btn);
    });

    rhythmDropzoneEl.addEventListener("dragover", (event) => {
      event.preventDefault();
      rhythmDropzoneEl.classList.add("is-over");
    });
    rhythmDropzoneEl.addEventListener("dragleave", () => {
      rhythmDropzoneEl.classList.remove("is-over");
    });
    rhythmDropzoneEl.addEventListener("drop", (event) => {
      event.preventDefault();
      rhythmDropzoneEl.classList.remove("is-over");
      if (!draggedPieceId) return;
      const piece = rhythmDeck.pieces.find((p) => p.id === draggedPieceId);
      if (!piece) return;
      measure.push(piece);
      renderMeasure();
    });

    rhythmDdCheckBtn.addEventListener("click", () => {
      const total = beatsInMeasure();
      const ok = total === rhythmDeck.targetBeats;
      progress.stats.rhythmTotal += 1;
      if (ok) progress.stats.rhythmCorrect += 1;
      saveProgress(progress);
      progress = addPracticeMinutes(0.5);
      renderStats();
      rhythmDdStatusEl.textContent = ok
        ? `Oikein! Tahti tayttyi tarkasti (${total}/${rhythmDeck.targetBeats}).`
        : `Ei viela oikein (${total}/${rhythmDeck.targetBeats}). Kokeile uudelleen.`;
    });

    rhythmDdResetBtn.addEventListener("click", () => {
      measure = [];
      renderMeasure();
    });

    nextRound();
    renderStats();
    renderMeasure();
  </script>
</BaseLayout>
