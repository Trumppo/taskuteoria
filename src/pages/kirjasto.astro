---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kirjasto | TaskuTeoria" active="kirjasto">
  <section class="card">
    <h1>Teoriakirjasto</h1>
    <p>Mini-opetukset 30-90 sekunnin paloissa + 3 valitonta harjoitusta per aihe.</p>
  </section>
  <section class="card">
    <h2>Nuottiarvot</h2>
    <p>Kokonuotti kestaa nelja iskua, puolinuotti kaksi, neljasosanuotti yhden.</p>
  </section>
  <section class="card">
    <h2>Tahtilajit</h2>
    <p>4/4 on yleisin perustahti, 3/4 valssimainen, 6/8 keinuvampi kahteen laskettava tuntuma.</p>
  </section>
  <section class="card">
    <h2>Intervallit</h2>
    <p>Sekunti, terssi, kvartti, kvintti, seksti, septimi, oktaavi - opi kuulemaan etaisyydet.</p>
  </section>
</BaseLayout>
