---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/base";
---

<BaseLayout title="TaskuTeoria" active="harjoittele">
  <section class="card">
    <h1>TaskuTeoria</h1>
    <p>Valitse osa-alue ja aloita harjoitus.</p>
  </section>

  <section class="card grid">
    <a class="btn" href={withBase("valitsin")}>Harjoitusvalitsin</a>
    <a class="btn ghost" href={withBase("harjoittele")}>Nuotit, rytmi, savellajit</a>
    <a class="btn ghost" href={withBase("kuuntele")}>Kuuntelu</a>
    <a class="btn ghost" href={withBase("kortit")}>Kortit (SRS)</a>
    <a class="btn ghost" href={withBase("pikavisa")}>Pikavisa</a>
    <a class="btn ghost" href={withBase("polku")}>14 paivan polku</a>
    <a class="btn ghost" href={withBase("kirjasto")}>Mini-opetus</a>
    <a class="btn ghost" href={withBase("asetukset")}>Asetukset</a>
  </section>
</BaseLayout>
