---
import "../styles/global.css";

interface Props {
  title: string;
  active?: string;
}

const { title, active = "" } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const withBase = (path: string) => new URL(path, `https://taskuteoria.local${base}`).pathname;

const nav = [
  { href: withBase("harjoittele"), label: "Harjoittele", key: "harjoittele" },
  { href: withBase("polku"), label: "Polku", key: "polku" },
  { href: withBase("kortit"), label: "Kortit", key: "kortit" },
  { href: withBase("kuuntele"), label: "Kuuntele", key: "kuuntele" },
  { href: withBase("kirjasto"), label: "Kirjasto", key: "kirjasto" },
];
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TaskuTeoria - staattinen mobiilioppiminen musiikin teoriaan" />
    <meta name="theme-color" content="#0b6e4f" />
    <link rel="manifest" href={withBase("manifest.webmanifest")} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <nav class="bottom-nav" aria-label="Pohjanavigaatio">
      {nav.map((item) => (
        <a href={item.href} class={active === item.key ? "active" : ""}>{item.label}</a>
      ))}
    </nav>
    <script>
      const base = import.meta.env.BASE_URL.endsWith("/")
        ? import.meta.env.BASE_URL
        : `${import.meta.env.BASE_URL}/`;
      const swPath = `${base}sw.js`;
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => navigator.serviceWorker.register(swPath));
      }
    </script>
  </body>
</html>
