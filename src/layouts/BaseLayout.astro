---
import "../styles/global.css";

interface Props {
  title: string;
  active?: string;
}

const { title, active = "" } = Astro.props;

const nav = [
  { href: "/harjoittele", label: "Harjoittele", key: "harjoittele" },
  { href: "/polku", label: "Polku", key: "polku" },
  { href: "/kortit", label: "Kortit", key: "kortit" },
  { href: "/kuuntele", label: "Kuuntele", key: "kuuntele" },
  { href: "/kirjasto", label: "Kirjasto", key: "kirjasto" },
];
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TaskuTeoria - staattinen mobiilioppiminen musiikin teoriaan" />
    <meta name="theme-color" content="#0b6e4f" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <nav class="bottom-nav" aria-label="Pohjanavigaatio">
      {nav.map((item) => (
        <a href={item.href} class={active === item.key ? "active" : ""}>{item.label}</a>
      ))}
    </nav>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => navigator.serviceWorker.register("/sw.js"));
      }
    </script>
  </body>
</html>
